<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Knarr Browser - Windows</title>
<style>
  body {
    font-family: Arial, sans-serif;
    background: #0f0f0f;
    color: white;
    text-align: center;
    padding: 60px;
  }
  .card {
    background: #1c1c1c;
    padding: 30px;
    border-radius: 15px;
    display: inline-block;
  }
  a.button {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 20px;
    background: #6c5ce7;
    color: white;
    text-decoration: none;
    border-radius: 10px;
    font-weight: bold;
  }
</style>
</head>

<body>

<div class="card">
  <img src="Knarr%20browser%20logo.png" width="120" style="border-radius:15px;" />

  <h1>Knarr Browser</h1>
  <h3>Windows Version</h3>

  <p>Download the installer for Windows.</p>

  <a class="button" href="../../releases/latest/download/Knarr-Setup.exe">
    Download for Windows
  </a>
</div>

</body>
</html>
